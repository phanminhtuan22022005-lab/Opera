<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Món quà bí mật 🎁</title>

<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}
.box{
    background:white;
    padding:30px;
    border-radius:20px;
    text-align:center;
    width:320px;
    box-shadow:0 10px 25px rgba(0,0,0,.2);
}
input{
    width:90%;
    padding:12px;
    font-size:18px;
    border-radius:10px;
    border:1px solid #ccc;
    text-align:center;
}
button{
    margin-top:15px;
    padding:12px 25px;
    border:none;
    border-radius:10px;
    background:#ff4d6d;
    color:white;
    font-size:17px;
    cursor:pointer;
}
#message{
    margin-top:20px;
    font-size:18px;
    line-height:1.6;
}
</style>
</head>

<body>

<div class="box">
<h2>🎁 Món quà bí mật</h2>
<p>Nhập mật khẩu 4 số</p>

<input type="password" id="code" maxlength="4">

<br>

<button onclick="check()">Mở quà</button>

<div id="message"></div>

</div>

<script>
const wishes = {
"1205":"🎉 Chúc mừng sinh nhật Tuấn! Chúc bạn luôn vui vẻ và thành công!",
"0817":"🎂 Chúc Lan luôn hạnh phúc, đạt được mọi điều mình mong muốn!",
"0302":"🎈 Chúc Minh thật nhiều sức khỏe và may mắn!"
};

function check(){
let code=document.getElementById("code").value;

if(wishes[code]){
document.getElementById("message").innerHTML=wishes[code];
}else{
document.getElementById("message").innerHTML="❌ Mật khẩu không đúng!";
}
}
</script>

</body>
</html>
